<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            fx:controller="com.taller.app.modules.configuracion.empresa.ui.EmpresaConfigController"
            stylesheets="@/css/empresa/empresa.css"
            userData="Empresa">

    <VBox spacing="25"
          alignment="TOP_CENTER"
          style="-fx-padding:25;">

        <VBox spacing="4" maxWidth="900">
            <Label text="Configuración de Empresa" styleClass="titulo"/>
            <Label text="Datos institucionales" styleClass="subtitulo"/>
        </VBox>

        <VBox spacing="25"
              maxWidth="900"
              styleClass="card">

            <HBox spacing="30">

                <VBox spacing="15" alignment="CENTER">

                    <ImageView fx:id="imgLogo"
                               fitWidth="140"
                               fitHeight="140"
                               preserveRatio="true"/>

                    <Button fx:id="btnBuscarLogo"
                            text="Seleccionar Logo"
                            onAction="#buscarLogo"
                            styleClass="btn-primary"/>

                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS">

                    <GridPane hgap="20" vgap="15">

                        <columnConstraints>
                            <ColumnConstraints minWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="RUC"/>
                        <TextField fx:id="txtRuc" GridPane.columnIndex="1"/>

                        <Label text="Razón Social"
                               GridPane.rowIndex="1"/>
                        <TextField fx:id="txtRazonSocial"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                        <Label text="Nombre Comercial"
                               GridPane.rowIndex="2"/>
                        <TextField fx:id="txtNombreComercial"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        <Label text="Dirección"
                               GridPane.rowIndex="3"/>
                        <TextField fx:id="txtDireccion"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="1"/>

                        <Label text="Teléfono"
                               GridPane.rowIndex="4"/>
                        <TextField fx:id="txtTelefono"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="1"/>

                        <Label text="Email"
                               GridPane.rowIndex="5"/>
                        <TextField fx:id="txtEmail"
                                   GridPane.rowIndex="5"
                                   GridPane.columnIndex="1"/>

                    </GridPane>

                </VBox>

            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">

                <Button fx:id="btnActualizar"
                        text="Actualizar"
                        onAction="#actualizar"
                        styleClass="btn-warning"/>

                <Button fx:id="btnGuardar"
                        text="Guardar"
                        onAction="#guardar"
                        styleClass="btn-primary"/>

                <Button fx:id="btnCancelar"
                        text="Cancelar"
                        onAction="#cancelar"
                        styleClass="btn-secondary"/>

            </HBox>

        </VBox>

    </VBox>

</ScrollPane>