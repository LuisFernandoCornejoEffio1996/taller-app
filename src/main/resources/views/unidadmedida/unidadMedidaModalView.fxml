<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taller.app.modules.configuracion.unidadMedida.ui.UnidadMedidaFormController"
      spacing="15"
      style="-fx-padding: 20;"
      userData="Unidad de Medida">

    <!-- TÍTULO -->
    <Label text="Unidad de Medida"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <!-- FORMULARIO -->
    <GridPane hgap="10" vgap="12">
        <columnConstraints>
            <ColumnConstraints prefWidth="120"/>
            <ColumnConstraints prefWidth="250"/>
        </columnConstraints>

        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Abreviatura:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtAbreviatura" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- BOTONES -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnActualizar" text="Actualizar" onAction="#actualizar" styleClass="btn-warning"/>
        <Button fx:id="btnGuardar" text="Guardar" onAction="#guardar" styleClass="btn-primary"/>
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#cancelar" styleClass="btn-secondary"/>
    </HBox>

</VBox>