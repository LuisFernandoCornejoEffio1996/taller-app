<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taller.app.modules.configuracion.empresa.controller.EmpresaConfigController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            stylesheets="@/css/empresa/empresaConfig.css">

    <VBox spacing="30" alignment="TOP_CENTER" style="-fx-padding: 40;">
        <!-- Título principal -->
        <VBox spacing="4" maxWidth="900">
            <Label text="Configuración de Empresa" styleClass="titulo"/>
            <Label text="Datos generales y logo institucional" styleClass="subtitulo"/>
        </VBox>
        <!-- Contenedor tipo tarjeta -->
        <VBox spacing="30" maxWidth="900" styleClass="card">

            <VBox spacing="15">
                <Label text="Datos Generales" styleClass="seccion"/>

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="RUC:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtRuc" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Razón Social:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtRazonSocial" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Nombre Comercial:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNombreComercial" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Dirección:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDireccion" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Teléfono:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTelefono" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Email:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEmail" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <VBox spacing="15">
                <Label text="Identidad Visual" styleClass="seccion"/>

                <HBox spacing="25" alignment="CENTER_LEFT">
                    <ImageView fx:id="imgLogo" fitWidth="160" fitHeight="160" preserveRatio="true" styleClass="logo"/>
                    <Button fx:id="btnBuscarLogo" text="Seleccionar Logo" onAction="#buscarLogo"/>
                </HBox>
            </VBox>

            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button fx:id="btnActualizar"
                        text=" Actualizar"
                        onAction="#actualizar"
                        styleClass="btn-success">

                    <graphic>
                        <FontAwesomeIconView glyphName="REFRESH" size="16"/>
                    </graphic>

                </Button>

                <Button fx:id="btnGuardar"
                        text=" Guardar"
                        onAction="#guardar"
                        styleClass="btn-primary">

                    <graphic>
                        <FontAwesomeIconView glyphName="SAVE" size="16"/>
                    </graphic>

                </Button>

                <Button fx:id="btnCancelar"
                        text=" Cancelar"
                        onAction="#cancelar"
                        styleClass="btn-secondary">

                    <graphic>
                        <FontAwesomeIconView glyphName="TIMES" size="16"/>
                    </graphic>

                </Button>
            </HBox>

        </VBox>

    </VBox>

</ScrollPane>
