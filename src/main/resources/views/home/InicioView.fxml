<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taller.app.ui.home.InicioController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            stylesheets="@/css/home/home.css">

    <VBox spacing="40" alignment="TOP_CENTER" style="-fx-padding: 40;">

        <VBox spacing="5" maxWidth="900">
            <Label text="Panel Principal" styleClass="titulo"/>
            <Label text="Bienvenido al Sistema ERP" styleClass="subtitulo"/>
        </VBox>

        <FlowPane hgap="25" vgap="25" alignment="CENTER" maxWidth="900" prefWrapLength="900">

            <VBox alignment="CENTER" prefWidth="220" prefHeight="160" spacing="12" styleClass="card">
                <FontAwesomeIconView glyphName="BUILDING" size="42" style="-fx-fill: #2980b9;"/>
                <Label text="Empresa" styleClass="card-title"/>
                <Button fx:id="btnEmpresa" text="Abrir" styleClass="btn-primary"/>
            </VBox>

            <VBox alignment="CENTER" prefWidth="220" prefHeight="160" spacing="12" styleClass="card">
                <FontAwesomeIconView glyphName="USER" size="42" style="-fx-fill: #27ae60;"/>
                <Label text="Usuarios" styleClass="card-title"/>
                <Button fx:id="btnUsuarios" text="Abrir" styleClass="btn-success"/>
            </VBox>

        </FlowPane>

    </VBox>

</ScrollPane>