<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Leer propiedad desde application-*.yml -->
    <springProperty scope="context" name="LOG_PATH" source="app.log-path"/>
    <!-- Fecha generada desde Java -->
    <property name="CURRENT_DATE" value="${CURRENT_DATE}"/>

    <!-- =============================== -->
    <!-- LOG DE APLICACIÓN               -->
    <!-- =============================== -->
    <appender name="APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/app/app-${CURRENT_DATE}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/app-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>15</maxHistory><!-- Fuerza rollover al iniciar -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>

        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="APP" level="DEBUG" additivity="false">
        <appender-ref ref="APP"/>
    </logger>

    <!-- =============================== -->
    <!-- LOG DE SEGURIDAD                -->
    <!-- =============================== -->
    <appender name="SECURITY" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/seguridad/security-${CURRENT_DATE}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/security-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="SECURITY" level="INFO" additivity="false">
        <appender-ref ref="SECURITY"/>
    </logger>

    <!-- ROOT LOGGER -->
    <root level="INFO">
        <appender-ref ref="APP"/>
    </root>

</configuration>